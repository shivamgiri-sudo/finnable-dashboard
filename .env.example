# Finnable Intelligence Dashboard — Node API + MySQL Pool
PORT=3000
NODE_ENV=development

# Portal login security
DASHBOARD_PIN=CHANGE_THIS_TO_YOUR_DASHBOARD_PIN
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_SECRET_MINIMUM_32_CHARACTERS
JWT_EXPIRES_IN=8h

# Existing live Finnable MySQL source
DB_HOST=122.184.128.90
DB_PORT=3306
DB_USER=shivam_user
DB_PASSWORD=PASTE_YOUR_MYSQL_PASSWORD_HERE
DB_DATABASE=db_external
DB_AUDIT_TABLE=CallDetails
DEFAULT_CLIENT_ID=497

# Optional Analyst/TL mapping SQL table. Leave blank if not available in SQL.
DB_MAPPING_TABLE=

# Connection-pool performance settings
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0
DB_CONNECT_TIMEOUT_MS=10000
DB_WARM_CONNECTIONS=2

# Use only when the database server requires TLS from this backend host.
DB_SSL=false
DB_SSL_REJECT_UNAUTHORIZED=true

# Dashboard data controls
MAX_SUMMARY_ROWS=50000
SUMMARY_CACHE_TTL_MS=15000
MAPPING_CACHE_TTL_MS=300000
